# --- Nix ---
# Ignore symlinks generated by `nix build`
result
result-*

# --- Direnv ---
# Ignore local environments created by nix-direnv
.direnv/

# --- Emacs ---
*~
\#*\#
.\#*

# --- Vim ---
[._]*.s[a-v][a-z]
*.swp
*.swo

# --- Local Overrides & Secrets ---
# Ignore any local-only config files
*.local

# --- Scratchpad & Testing ---
# Ignore directories for local experiments, temporary scripts, or test builds
scratch/
testing/